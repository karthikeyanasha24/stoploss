# API: Tradier (recommended), Alpha Vantage, Massive, or Finnhub. Do not commit real keys.
API_PROVIDER=tradier
API_KEY=your_tradier_api_token_here
# Tradier: PAPER_TRADING=true for sandbox, false for live
PAPER_TRADING=true
# Or: TRADIER_API_KEY=... | ALPHAVANTAGE_API_KEY=... | MASSIVE_API_KEY=... | FINNHUB_API_KEY=...

# Optional: mock API for testing (no real HTTP)
MOCK_API=false

# Google Sheets — use env vars (no credentials.json file needed)
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_PRIVATE_KEY_ID=your-private-key-id
# Option A: GOOGLE_PRIVATE_KEY_BASE64 (recommended for Render — no newline issues)
# Run: python -c "import base64,json; print(base64.b64encode(json.load(open('credentials.json'))['private_key'].encode()).decode())"
GOOGLE_PRIVATE_KEY_BASE64=LS0tLS1CRUdJTiBQUklWQVRFIEtFWS0tLS0t...
# Option B: GOOGLE_PRIVATE_KEY with \n for newlines (can fail on some hosts)
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_CLIENT_ID=123456789
# Optional (defaults shown):
# GOOGLE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
# GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
# GOOGLE_UNIVERSE_DOMAIN=googleapis.com
SPREADSHEET_ID=your_google_sheet_id_here

# Database (SQLite)
DB_PATH=data/version_b.db

# Scheduler (increase to 300 if tracker runs >60s and you see "max instances reached")
POLLING_INTERVAL=300
MARKET_TIMEZONE=US/Eastern
MARKET_OPEN=09:30
MARKET_CLOSE=16:00

# Analysis
ANALYSIS_DAYS=7

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Optional: serve REST API
API_SERVE=false
PORT=8000
